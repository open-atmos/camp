{
  "multiple-boxes": "monte carlo",
  "experiment-name": "testing",
  "boxmodel-data": [
    {
      "name": "species map",
      "type": "SPECIES_MAP",
      "mechanism_name": "MONARCH mod37",
      "gas-phase water": "H2O",
      "gas-phase water dimer": "H2O_dimer",
      "photolysis_method": "CLOUDJ",
      "photolysis_table": true
    },
    {
      "name": "everything related to time",
      "type": "TIME_CONTROL",
      "time_control": {
        "start_time": {
          "year": 2018,
          "month": 8,
          "day": 13,
          "hour": 0,
          "tz": 0
        },
        "simulation_length": {
          "time": 1,
          "unit": "days"
        },
        "timestep": {
          "time": 15.0,
          "unit": "min"
        }
      }
    },
    {
      "name": "Initial concentrations",
      "type": "INIT_CONC",
      "gas-phase species": {
        "ISOP": {
          "init conc": {
            "value": 1.0,
            "unit": "ppb"
          }
        },
        "SO2": {
          "init conc": {
            "value": 1.0,
            "unit": "ppb"
          }
        },
        "NO2": {
          "init conc": {
            "value": 0.3,
            "unit": "ppb"
          }
        },
        "HNO3": {
          "init conc": {
            "value": 0.3,
            "unit": "ppb"
          }
        },
        "NH3": {
          "init conc": {
            "value": 100.0,
            "unit": "ppt"
          }
        },
        "O3": {
          "init conc": {
            "value": 30.0,
            "unit": "ppb"
          }
        },
        "H2O2": {
          "init conc": {
            "value": 1.0,
            "unit": "ppb"
          }
        },
        "CO": {
          "init conc": {
            "value": 150.0,
            "unit": "ppb"
          }
        },
        "FACD": {
          "init conc": {
            "value": 0.5,
            "unit": "ppb"
          }
        },
        "MEOH": {
          "init conc": {
            "value": 2.0,
            "unit": "ppb"
          }
        },
        "MEPX": {
          "init conc": {
            "value": 0.01,
            "unit": "ppb"
          }
        },
        "CH4": {
          "init conc": {
            "value": 1700.0,
            "unit": "ppb"
          }
        },
        "M": {
          "note": "by definition the third body is the concentration of air molecules = 1 ppp",
          "init conc": {
            "value": 1.0,
            "unit": "ppp"
          }
        },
        "O2": {
          "note": "molecular oxygen is a constant fraction of air molecules = 0.2095 ppp",
          "init conc": {
            "value": 0.2095,
            "unit": "ppp"
          }
        }
      },
      "aerosol-phase species": {
        "clouds and rain.cloud and rain water.H2O_aq": {
          "init conc": {
            "value": 1e-12,
            "unit": "kg/m3"
          },
          "aerosol representation name": "multiphase sectional"
        }
      }
    },
    {
      "name": "latitude",
      "type": "LATITUDE",
      "constant_constraint": {
        "value": 41.382778,
        "unit": "deg",
        "montecarlo": {
          "type": "uniform",
          "relative_factor": 0.5,
          "lower_bound": 0.0,
          "upper_bound": 90.0
        }
      }
    },
    {
      "name": "longitude",
      "type": "LONGITUDE",
      "constant_constraint": {
        "value": 50,
        "unit": "deg"
      }
    },
    {
      "name": "altitude",
      "type": "ALTITUDE",
      "constant_constraint": {
        "value": 200.0,
        "unit": "m"
      }
    },
    {
      "name": "pressure",
      "type": "PRESSURE",
      "constant_constraint": {
        "value": 1.0,
        "unit": "atm"
      }
    },
    {
      "name": "temperature",
      "type": "TEMPERATURE",
      "constant_constraint": {
        "value": 298.0,
        "unit": "K"
      }
    },
    {
      "name": "humidity",
      "type": "HUMIDITY",
      "constant_constraint": {
        "value": 90.0,
        "unit": "%"
      }
    },
    {
      "name": "box height",
      "type": "HEIGHT",
      "constant_constraint": {
        "value": 1.0,
        "unit": "km"
      }
    },
    {
      "name": "solar zenith angle (optional)",
      "type": "SZA",
      "constant_constraint": {
        "value": 90.0,
        "unit": "deg",
        "montecarlo": {
          "type": "uniform",
          "relative_factor": 1.0,
          "lower_bound": 0.0,
          "upper_bound": 180.0
        }
      }
    },
    {
      "name": "microphysics constraints",
      "type": "MICROPHYSICS",
      "aerosol_representation": "multiphase sectional",
      "constraints": {
        "clouds and rain": {
          "mean_diameter": {
            "constant_constraint": {
              "value": 50.0,
              "unit": "um"
            }
          },
          "stdev": {
            "constant_constraint": {
              "value": 2.1,
              "unit": "dimensionless"
            }
          }
        }
      }
    },
    {
      "name": "Constrained concentrations",
      "type": "FORCED_CONC",
      "gas-phase species": {
        "CO": {
          "file_constraint": {
            "filename": "co.csv",
            "time_unit": "h",
            "value_unit": "ppb",
            "header": 1,
            "separator": ",",
            "diurnal": "y"
          }
        }
      },
      "aerosol-phase species": {
        "clouds and rain.cloud and rain water.H2O_aq": {
          "file_constraint": {
            "filename": "cloud_water_content.csv",
            "time_unit": "h",
            "value_unit": "kg/m3",
            "header": 1,
            "separator": ",",
            "diurnal": "y"
          },
          "aerosol representation name": "multiphase sectional"
        }
      }
    }
  ]
}